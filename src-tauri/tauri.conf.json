{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Card Editor",
  "version": "0.1.0",
  "identifier": "com.everton.cardeditor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build"
  },
  "app": {
    "windows": [
      {
        "title": "Card Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Everton",
    "category": "Productivity",
    "shortDescription": "Editor visual de cartas.",
    "longDescription": "Editor visual de cartas com camadas, assets, templates e exportacao em PNG.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
